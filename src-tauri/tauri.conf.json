{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flashcards",
  "version": "0.5.0",
  "identifier": "com.flashcards.app",
  "build": {
    "beforeDevCommand": "pnpm vite --host 127.0.0.1",
    "beforeBuildCommand": "pnpm vite build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Flashcards",
        "width": 800,
        "height": 600,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "hiddenTitle": true,
        "windowEffects": {
          "effects": [
            "acrylic"
          ],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxMTEwQ0RDQ0IxMEJBQ0MKUldUTXVoREwzQXdSMGRrNnJNRXZxeEQ5RndlSk1NYWU2dXh2blFOeE0zbjFNRG1JV2Mxck50dWEK",
      "endpoints": [
        "https://github.com/meephub/flashcards-windows/releases/latest/download/latest.json"
      ]
    }
  }
}