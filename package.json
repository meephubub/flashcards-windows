{
  "name": "flashcards-windows",
  "private": true,
  "version": "0.15.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n ai,tauri -c cyan,white \"bun run server/ai-sidecar.mjs\" \"tauri dev\"",
    "dev:web": "vite --host 127.0.0.1",
    "build:web": "dotenv -e .env -- vite build",
    "dev:tauri": "tauri dev",
    "ai": "bun run server/ai-sidecar.mjs",
    "build": "dotenv -e .env -- bun run build:sidecar && tauri build",
    "build:sidecar": "bun build ./server/ai-sidecar.mjs --compile --target=bun-windows-x64 --outfile ./src-tauri/binaries/ai-sidecar.exe",
    "preview": "tauri preview",
    "release": "node scripts/release-tui.js"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.39",
    "@logtail/browser": "^0.5.8",
    "@logtail/node": "^0.5.8",
    "@mastra/core": "^1.37.1",
    "@mastra/libsql": "^1.11.1",
    "@mastra/memory": "^1.20.0",
    "@mdxeditor/editor": "^4.0.1",
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "ogl": "^1.0.11",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "ts-fsrs": "^5.4.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "blessed": "^0.1.81",
    "bun": "^1.1.0",
    "dotenv-cli": "^11.0.0",
    "typescript": "^5.2.2"
  }
}